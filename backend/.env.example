# Copy to .env and fill in values

# Generate with: python generate_hash.py yourpassword
ADMIN_PASSWORD_HASH=

ADMIN_USERNAME=admin

# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# SQLite (default) — for production consider PostgreSQL on Neon/Supabase
DATABASE_URL=sqlite:///./portfolio.db

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-portfolio.vercel.app
